# ============================================================
# 环境变量配置模板（复制为 .env 后填入真实值）
# .env 含敏感信息，已被 .gitignore 排除，不会提交到仓库
# ============================================================

# MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=subjects_kg

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE_NAME=milvus_demo
MILVUS_COLLECTION_NAME=edurag

# LLM（DashScope）
LLM_MODEL=qwen-plus
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 检索参数
PARENT_CHUNK_SIZE=1200
CHILD_CHUNK_SIZE=300
CHUNK_OVERLAP=50
RETRIEVAL_K=3
CANDIDATE_M=2

# 应用
VALID_SOURCES=["ai", "java", "test", "ops", "bigdata"]
CUSTOMER_SERVICE_PHONE=13000000000
